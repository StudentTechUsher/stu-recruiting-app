      "deduplication_key": "env+parser_model",
      "auto_close_condition": "count(status='processing' AND age_minutes>20) < 2 for 10m",
      "paging_eligibility": "24x7",
      "data_source_type": "db-derived",
      "runbook_id": "RB-TRANSCRIPT-STUCK-001",
      "dashboard_panel_ids": [
        "PANEL-EXTRACT-004"
      ]
    },
