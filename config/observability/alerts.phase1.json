{
  "config_id": "OBS-ALERT-CONFIG-001",
  "version": "1.0",
  "defaults": {
    "business_hours_response": true,
    "sev1_paging_24x7": true,
    "sev2_after_hours_paging_allowed": false
  },
  "alerts": [
    {
      "alert_id": "ALRT-API-5XX-RATE-HIGH",
      "severity": "Sev1",
      "aggregation_window": "5m",
      "sustain_period": "10m",
      "threshold_formula": "server_error_count / request_count > 0.10",
      "ratio_rule": {
        "numerator": "server_error_count",
        "denominator": "request_count",
        "window": "5m",
        "minimum_denominator_volume": "request_count >= 100"
      },
      "minimum_sample_volume": "request_count >= 100",
      "deduplication_key": "env+service+route_template",
      "auto_close_condition": "server_error_count / request_count <= 0.03 for 15m",
      "paging_eligibility": "24x7",
      "data_source_type": "metric",
      "runbook_id": "RB-API-5XX-001",
      "dashboard_panel_ids": [
        "PANEL-API-001",
        "PANEL-API-002"
      ]
    },
    {
      "alert_id": "ALRT-AUTH-MAGIC-LINK-FAILURE-SPIKE",
      "severity": "Sev2",
      "aggregation_window": "15m",
      "sustain_period": "10m",
      "threshold_formula": "magic_link_failed / magic_link_attempted > 0.08",
      "ratio_rule": {
        "numerator": "magic_link_failed",
        "denominator": "magic_link_attempted",
        "window": "15m",
        "minimum_denominator_volume": "magic_link_attempted >= 50"
      },
      "minimum_sample_volume": "magic_link_attempted >= 50",
      "deduplication_key": "env+persona+route_template+error_code",
      "auto_close_condition": "magic_link_failed / magic_link_attempted <= 0.03 for 30m",
      "paging_eligibility": "business_hours_only",
      "data_source_type": "metric",
      "runbook_id": "RB-AUTH-MAGIC-LINK-001",
      "dashboard_panel_ids": [
        "PANEL-AUTH-001",
        "PANEL-AUTH-002"
      ]
    },
    {
      "alert_id": "ALRT-EXTRACT-RESUME-FAILURE-RATE",
      "severity": "Sev2",
      "severity_override": "Sev1 if resume_extract_success == 0 for 15m with attempted >= 25",
      "aggregation_window": "15m",
      "sustain_period": "10m",
      "threshold_formula": "resume_extract_failed / resume_extract_attempted > 0.10",
      "ratio_rule": {
        "numerator": "resume_extract_failed",
        "denominator": "resume_extract_attempted",
        "window": "15m",
        "minimum_denominator_volume": "resume_extract_attempted >= 25"
      },
      "minimum_sample_volume": "resume_extract_attempted >= 25",
      "deduplication_key": "env+route_template+outcome",
      "auto_close_condition": "resume_extract_failed / resume_extract_attempted <= 0.04 for 30m",
      "paging_eligibility": "business_hours_only",
      "data_source_type": "metric",
      "runbook_id": "RB-EXTRACT-RESUME-001",
      "dashboard_panel_ids": [
        "PANEL-EXTRACT-001",
        "PANEL-EXTRACT-002"
      ]
    },
    {
      "alert_id": "ALRT-EXTRACT-RESUME-ZERO-SUCCESS",
      "severity": "Sev1",
      "aggregation_window": "15m",
      "sustain_period": "15m",
      "threshold_formula": "resume_extract_success == 0 AND resume_extract_attempted >= 20",
      "minimum_sample_volume": "resume_extract_attempted >= 20",
      "deduplication_key": "env+route_template",
      "auto_close_condition": "resume_extract_success >= 1 in 10m",
      "paging_eligibility": "24x7",
      "data_source_type": "metric",
      "runbook_id": "RB-EXTRACT-RESUME-001",
      "dashboard_panel_ids": [
        "PANEL-EXTRACT-001"
      ]
    },
    {
      "alert_id": "ALRT-TRANSCRIPT-PARSE-FAILED-RATE",
      "severity": "Sev2",
      "aggregation_window": "15m",
      "sustain_period": "10m",
      "threshold_formula": "parse_failed / parse_attempted > 0.12",
      "ratio_rule": {
        "numerator": "parse_failed",
        "denominator": "parse_attempted",
        "window": "15m",
        "minimum_denominator_volume": "parse_attempted >= 20"
      },
      "minimum_sample_volume": "parse_attempted >= 20",
      "deduplication_key": "env+route_template+parser_model",
      "auto_close_condition": "parse_failed / parse_attempted <= 0.05 for 30m",
