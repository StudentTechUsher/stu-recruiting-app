          "linked_slo_id": "SLO-TRANSCRIPT-PARSE-001"
        },
        {
          "panel_id": "PANEL-EXTRACT-004",
          "panel_name": "Transcript Sessions Stuck Processing",
          "query_intent": "Count sessions in processing state for >20m.",
          "query_template": "count(db.transcript_parse_sessions{status=processing, age_minutes>20})",
          "linked_metrics": [
            "stu_transcript_processing_stuck_count"
          ],
          "linked_slo_id": null
        },
        {
          "panel_id": "PANEL-EXTRACT-005",
          "panel_name": "OpenAI Extraction Failure Ratio",
          "query_intent": "Monitor OpenAI dependency reliability for extraction operations.",
          "query_template": "sum(stu_openai_extract_failed_total) / sum(stu_openai_extract_attempt_total)",
          "linked_metrics": [
            "stu_openai_extract_failed_total",
