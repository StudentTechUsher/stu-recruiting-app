{
  "config_id": "OBS-DASH-CONFIG-001",
  "version": "1.0",
  "dashboards": [
    {
      "dashboard_id": "DASH-API-001",
      "name": "API Reliability Overview",
      "owner_role": "Backend Engineer",
      "panels": [
        {
          "panel_id": "PANEL-API-001",
          "panel_name": "API Success Ratio",
          "query_intent": "Track 30d availability ratio for core API routes.",
          "query_template": "1 - (sum(stu_api_server_errors_total) / sum(stu_api_requests_total))",
          "linked_metrics": [
            "stu_api_requests_total",
            "stu_api_server_errors_total"
          ],
          "linked_slo_id": "SLO-API-AVAIL-001"
        },
        {
          "panel_id": "PANEL-API-002",
          "panel_name": "5XX Rate by Route Template",
          "query_intent": "Detect concentrated 5xx regressions by route_template.",
          "query_template": "sum(stu_api_server_errors_total{route_template=*}) / sum(stu_api_requests_total{route_template=*})",
          "linked_metrics": [
            "stu_api_server_errors_total",
            "stu_api_requests_total"
          ],
          "linked_slo_id": null
        },
        {
          "panel_id": "PANEL-API-003",
          "panel_name": "Unexpected Error Events (Sentry)",
          "query_intent": "Monitor unexpected exception volume by release and route_template.",
          "query_template": "count(sentry.issue_events{error_class=unexpected_exception})",
          "linked_metrics": [
            "sentry_issue_events_total"
          ],
          "linked_slo_id": null
        }
      ]
    },
    {
      "dashboard_id": "DASH-AUTH-001",
      "name": "Auth and Session Health",
      "owner_role": "Backend Engineer",
      "panels": [
        {
          "panel_id": "PANEL-AUTH-001",
          "panel_name": "Magic Link Success Ratio",
          "query_intent": "Track 30d auth initiation reliability by persona.",
          "query_template": "sum(stu_auth_magic_link_sent_total) / sum(stu_auth_magic_link_attempt_total)",
          "linked_metrics": [
            "stu_auth_magic_link_sent_total",
            "stu_auth_magic_link_attempt_total"
          ],
          "linked_slo_id": "SLO-AUTH-LOGIN-001"
        },
        {
          "panel_id": "PANEL-AUTH-002",
          "panel_name": "Magic Link Failures by Error Code",
          "query_intent": "Identify failure clusters and top error_code contributors.",
          "query_template": "sum(stu_auth_magic_link_failed_total{error_code=*}) by error_code",
          "linked_metrics": [
            "stu_auth_magic_link_failed_total"
          ],
          "linked_slo_id": null
        }
      ]
    },
    {
      "dashboard_id": "DASH-EXTRACT-001",
      "name": "Artifact Extraction and Parsing",
      "owner_role": "Backend Engineer",
      "panels": [
        {
          "panel_id": "PANEL-EXTRACT-001",
          "panel_name": "Resume Extraction Success Ratio",
          "query_intent": "Track extraction reliability and detect outages quickly.",
          "query_template": "sum(stu_extract_resume_success_total) / sum(stu_extract_resume_attempt_total)",
          "linked_metrics": [
            "stu_extract_resume_success_total",
            "stu_extract_resume_attempt_total"
          ],
          "linked_slo_id": "SLO-EXTRACT-RESUME-001"
        },
        {
          "panel_id": "PANEL-EXTRACT-002",
          "panel_name": "Resume Extraction Failures by Error Code",
          "query_intent": "Break down extraction failures by dependency and error_code.",
          "query_template": "sum(stu_extract_resume_failed_total{error_code=*}) by error_code",
          "linked_metrics": [
            "stu_extract_resume_failed_total"
          ],
          "linked_slo_id": null
        },
        {
          "panel_id": "PANEL-EXTRACT-003",
          "panel_name": "Transcript Parse Success Ratio",
          "query_intent": "Track parser reliability over 30d.",
          "query_template": "sum(stu_transcript_parse_success_total) / sum(stu_transcript_parse_attempt_total)",
